FROM golang:1.24-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o /out/market-data ./market-data/cmd/market-data

FROM alpine:3.21

WORKDIR /workspace/backend/go-service

COPY --from=builder /out/market-data /usr/local/bin/market-data
COPY market-data/configs/ market-data/configs/

CMD ["market-data", "-config", "market-data/configs/local.toml"]
